{
  "name": "cdd-for-claude-code",
  "displayName": "CDD for Claude Code — Copilot Driven Dev",
  "description": "Visual explorer and AI agent for CDD (Copilot-Driven Development) methodology. Manage modules, skills, rules, and stacks for Claude Code projects.",
  "version": "0.4.0",
  "publisher": "danilorangelmg",
  "license": "MIT",
  "icon": "resources/cdd-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/danilorangelmg/cdd-kit-vscode"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "claude-code",
    "copilot-driven-development",
    "cdd",
    "ai-development",
    "methodology",
    "multi-agent"
  ],
  "activationEvents": [
    "workspaceContains:cdd.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cdd-explorer",
          "title": "CDD",
          "icon": "resources/icons/cdd-activity.svg"
        }
      ]
    },
    "views": {
      "cdd-explorer": [
        {
          "id": "cddExplorer",
          "name": "Explorer"
        },
        {
          "id": "cddClaudeMd",
          "name": "CLAUDE.md",
          "type": "webview"
        },
        {
          "id": "cddChat",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "cdd.initProject",
        "title": "CDD: Init Project",
        "icon": "$(add)"
      },
      {
        "command": "cdd.addModule",
        "title": "CDD: Add Module",
        "icon": "$(add)"
      },
      {
        "command": "cdd.addStack",
        "title": "CDD: Add/Change Stack",
        "icon": "$(symbol-property)"
      },
      {
        "command": "cdd.runDoctor",
        "title": "CDD: Run Doctor",
        "icon": "$(heart)"
      },
      {
        "command": "cdd.regenerate",
        "title": "CDD: Regenerate Infrastructure",
        "icon": "$(refresh)"
      },
      {
        "command": "cdd.askAgent",
        "title": "CDD: Ask CDD Agent",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "cdd.loginAnthropic",
        "title": "CDD: Login Anthropic"
      },
      {
        "command": "cdd.logoutAnthropic",
        "title": "CDD: Logout Anthropic"
      },
      {
        "command": "cdd.refreshTree",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "cdd.toggleRule",
        "title": "CDD: Toggle Rule",
        "icon": "$(check)"
      },
      {
        "command": "cdd.createSkill",
        "title": "CDD: Create Skill",
        "icon": "$(add)"
      },
      {
        "command": "cdd.createHook",
        "title": "CDD: Create Hook",
        "icon": "$(add)"
      },
      {
        "command": "cdd.applyPreset",
        "title": "CDD: Apply Preset",
        "icon": "$(symbol-enum)"
      },
      {
        "command": "cdd.editSkill",
        "title": "CDD: Edit Skill",
        "icon": "$(edit)"
      },
      {
        "command": "cdd.deleteSkill",
        "title": "CDD: Delete Skill",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cdd.addModule",
          "when": "view == cddExplorer",
          "group": "navigation"
        },
        {
          "command": "cdd.applyPreset",
          "when": "view == cddExplorer",
          "group": "navigation"
        },
        {
          "command": "cdd.refreshTree",
          "when": "view == cddExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cdd.addStack",
          "when": "view == cddExplorer && viewItem == module",
          "group": "inline"
        },
        {
          "command": "cdd.toggleRule",
          "when": "view == cddExplorer && viewItem == rule",
          "group": "inline"
        },
        {
          "command": "cdd.createSkill",
          "when": "view == cddExplorer && viewItem == skillsCategory",
          "group": "inline"
        },
        {
          "command": "cdd.createHook",
          "when": "view == cddExplorer && viewItem == hooksCategory",
          "group": "inline"
        },
        {
          "command": "cdd.editSkill",
          "when": "view == cddExplorer && viewItem == skill",
          "group": "inline"
        },
        {
          "command": "cdd.deleteSkill",
          "when": "view == cddExplorer && viewItem == skill"
        }
      ]
    },
    "configuration": {
      "title": "CDD for Claude Code",
      "properties": {
        "cdd.anthropic.model": {
          "type": "string",
          "default": "claude-sonnet-4-6-20250414",
          "enum": [
            "claude-haiku-4-5-20251001",
            "claude-sonnet-4-6-20250414",
            "claude-opus-4-6-20250414"
          ],
          "enumDescriptions": [
            "Claude Haiku 4.5 — Fast, lightweight",
            "Claude Sonnet 4.6 — Balanced (recommended)",
            "Claude Opus 4.6 — Most capable"
          ],
          "description": "Claude model to use for the CDD Agent"
        },
        "cdd.agent.maxTokens": {
          "type": "number",
          "default": 2048,
          "description": "Maximum tokens for agent responses"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package",
    "publish": "vsce publish",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "cdd-kit": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
